e_path)\n        dest_path = get_destination_path(file_path, category, directory, dry_run)\n        move_file(file_path, dest_path, dry_run)\n    \n    if dry_run:\n        print(f\"[DRY-RUN] Would organize {len(files)} files\")\n    else:\n        print(f\"Organized {len(files)} files\")\n}"},"output":"Wrote file successfully.","title":"utils.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_195450/utils.py","exists":false,"truncated":false},"time":{"start":1772931747699,"end":1772931747729}}}}
