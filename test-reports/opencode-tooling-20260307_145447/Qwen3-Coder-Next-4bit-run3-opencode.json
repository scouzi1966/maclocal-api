actions: list[tuple[Path, Path]] = []\n\n    def scan_files(self) -> list[Path]:\n        \"\"\"Scan and return all files in the directory.\"\"\"\n        return get_files_in_directory(self.directory)\n\n    def get_file_category(self, file_path: Path) -> str:\n        \"\"\"Get the category for a file.\"\"\"\n        return get_category(file_path)\n\n    def prepare_organisation(self) -> list[tuple[Path, str]]:\n        \"\"\"Prepare organization plan without moving files.\"\"\"\n        files = self.scan_files()\n        plan = []\n        for file_path in files:\n            category = self.get_file_category(file_path)\n            plan.append((file_path, category))\n        return plan\n\n    def organize(self, dry_run: bool = False) -> list[tuple[Path, Path]]:\n        \"\"\"Organize files into category folders.\n\n        Args:\n            dry_run: If True, only return planned actions without moving files.\n\n        Returns:\n            List of (source, destination) tuples for moved files.\n        \"\"\"\n        files = self.scan_files()\n        moved_files: list[tuple[Path, Path]] = []\n\n        for file_path in files:\n            category = self.get_file_category(file_path)\n            category_folder = self.directory / category\n\n            if dry_run:\n                self.actions.append((file_path, category_folder / file_path.name))\n            else:\n                create_folder(category_folder)\n                destination = category_folder / file_path.name\n                file_path.rename(destination)\n                self.actions.append((file_path, destination))\n                moved_files.append((file_path, destination))\n\n        return moved_files\n\n    def get_summary(self) -> dict[str, int]:\n        \"\"\"Get a summary of organized files by category.\"\"\"\n        summary: dict[str, int] = {}\n        for _, destination in self.actions:\n            category = destination.parent.name\n            summary[category] = summary.get(category, 0) + 1\n        return summary\n\n\ndef organize_directory(\n    directory: Path, dry_run: bool = False\n) -> list[tuple[Path, Path]]:\n    \"\"\"Organize files in a directory.\n\n    Args:\n        directory: Path to the directory to organize.\n        dry_run: If True, only preview actions without moving files.\n\n    Returns:\n        List of (source, destination) tuples for moved files.\n    \"\"\"\n    organizer = FileOrganizer(directory)\n    return organizer.organize(dry_run=dry_run)\n","after":"\"\"\"Core organizer logic for the file organizer.\"\"\"\n\nfrom pathlib import Path\n\nfrom file_types import get_category\nfrom utils import create_folder, get_files_in_directory, is_directory\n\n\nclass FileOrganizer:\n    \"\"\"Organizes files in a directory into categorized folders.\"\"\"\n\n    def __init__(self, directory: Path):\n        \"\"\"Initialize with a target directory.\"\"\"\n        self.directory = directory\n        self.actions: list[tuple[Path, Path]] = []\n\n    def scan_files(self) -> list[Path]:\n        \"\"\"Scan and return all files in the directory.\"\"\"\n        return get_files_in_directory(self.directory)\n\n    def get_file_category(self, file_path: Path) -> str:\n        \"\"\"Get the category for a file.\"\"\"\n        return get_category(file_path)\n\n    def prepare_organisation(self) -> list[tuple[Path, str]]:\n        \"\"\"Prepare organization plan without moving files.\"\"\"\n        files = self.scan_files()\n        plan = []\n        for file_path in files:\n            category = self.get_file_category(file_path)\n            plan.append((file_path, category))\n        return plan\n\n    def organize(self, dry_run: bool = False) -> list[tuple[Path, Path]]:\n        \"\"\"Organize files into category folders.\n\n        Args:\n            dry_run: If True, only return planned actions without moving files.\n\n        Returns:\n            List of (source, destination) tuples for moved files.\n        \"\"\"\n        files = self.scan_files()\n        moved_files: list[tuple[Path, Path]] = []\n\n        for file_path in files:\n            category = self.get_file_category(file_path)\n            category_folder = self.directory / category\n            destination = category_folder / file_path.name\n\n            if dry_run:\n                self.actions.append((file_path, destination))\n                moved_files.append((file_path, destination))\n            else:\n                create_folder(category_folder)\n                file_path.rename(destination)\n                self.actions.append((file_path, destination))\n                moved_files.append((file_path, destination))\n\n        return moved_files\n\n    def get_summary(self) -> dict[str, int]:\n        \"\"\"Get a summary of organized files by category.\"\"\"\n        summary: dict[str, int] = {}\n        for _, destination in self.actions:\n            category = destination.parent.name\n            summary[category] = summary.get(category, 0) + 1\n        return summary\n\n\ndef organize_directory(\n    directory: Path, dry_run: bool = False\n) -> list[tuple[Path, Path]]:\n    \"\"\"Organize files in a directory.\n\n    Args:\n        directory: Path to the directory to organize.\n        dry_run: If True, only preview actions without moving files.\n\n    Returns:\n        List of (source, destination) tuples for moved files.\n    \"\"\"\n    organizer = FileOrganizer(directory)\n    return organizer.organize(dry_run=dry_run)\n","additions":3,"deletions":2},"truncated":false},"time":{"start":1772917337893,"end":1772917337929}}}}
