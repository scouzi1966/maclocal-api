()\n50:     return EXTENSION_TO_CATEGORY.get(ext, \"Other\")\n51: \n52: \n53: def get_all_categories() -> list[str]:\n54:     \"\"\"Get all supported category names.\"\"\"\n55:     return list(FILE_CATEGORIES.keys())\n\n(End of file - total 55 lines)\n</content>","title":"file_types.py","metadata":{"preview":"\"\"\"File type mappings for the file organizer.\"\"\"\n\nfrom pathlib import Path\n\nFILE_CATEGORIES = {\n    \"Images\": [\".jpg\", \".jpeg\", \".png\", \".gif\", \".bmp\", \".svg\", \".webp\", \".tiff\"],\n    \"Documents\": [\n        \".pdf\",\n        \".docx\",\n        \".doc\",\n        \".txt\",\n        \".rtf\",\n        \".xlsx\",\n        \".xls\",\n        \".pptx\",\n        \".ppt\",\n        \".odt\",\n        \".odp\",\n    ],\n    \"Videos\": [\".mp4\", \".mov\", \".avi\", \".mkv\", \".flv\", \".wmv\", \".webm\"],","truncated":false,"loaded":[]},"time":{"start":1772917012654,"end":1772917012656}}}}
{"type":"tool_use","timestamp":1772917013201,"sessionID":"ses_335ec3464ffedfSGWTaZzbcVUq","part":{"id":"prt_cca16b928001YOCQF6wYqOer14","sessionID":"ses_335ec3464ffedfSGWTaZzbcVUq","messageID":"msg_cca16405c001xry5BX5mhldkZ7","type":"tool","callID":"call_6A1A4C4EEB3143B6B842C3F9","tool":"read","state":{"status":"completed","input":{"filePath":"/private/tmp/opencode-serve-test/organizer.py"},"output":"<path>/private/tmp/opencode-serve-test/organizer.py</path>\n<type>file</type>\n<content>1: \"\"\"Core organizer logic for the file organizer.\"\"\"\n2: \n3: from pathlib import Path\n4: \n5: from file_types import get_category\n6: from utils import create_folder, get_files_in_directory, is_directory\n7: \n8: \n9: class FileOrganizer:\n10:     \"\"\"Organizes files in a directory into categorized folders.\"\"\"\n11: \n12:     def __init__(self, directory: Path):\n13:         \"\"\"Initialize with a target directory.\"\"\"\n14:         self.directory = directory\n15:         self.actions: list[tuple[Path, Path]] = []\n16: \n17:     def scan_files(self) -> list[Path]:\n18:         \"\"\"Scan and return all files in the directory.\"\"\"\n19:         return get_files_in_directory(self.directory)\n20: \n21:     def get_file_category(self, file_path: Path) -> str:\n22:         \"\"\"Get the category for a file.\"\"\"\n23:         return get_category(file_path)\n24: \n25:     def prepare_organisation(self) -> list[tuple[Path, str]]:\n26:         \"\"\"Prepare organization plan without moving files.\"\"\"\n27:         files = self.scan_files()\n28:         plan = []\n29:         for file_path in files:\n30:             category = self.get_file_category(file_path)\n31:             plan.append((file_path, category))\n32:         return plan\n33: \n34:     def organize(self, dry_run: bool = False) -> list[tuple[Path, Path]]:\n35:         \"\"\"Organize files into category folders.\n36: \n37:         Args:\n38:             dry_run: If True, only return planned actions without moving files.\n39: \n40:         Returns:\n41:             List of (source, destination) tuples for moved files.\n42:         \"\"\"\n43:         files = self.scan_files()\n44:         moved_files: list[tuple[Path, Path]] = []\n45: \n46:         for file_path in files:\n47:             category = self.get_file_category(file_path)\n48:             category_folder = self.directory / category\n49: \n50:             if dry_run:\n51:                 self.actions.append((file_path, category_folder / file_path.name))\n52:             else:\n53:                 create_folder(category_folder)\n54:                 destination = category_folder / file_path.name\n55:                 file_path.rename(destination)\n56:                 self.actions.append((file_path, destination))\n57:                 moved_files.append((file_path, destination))\n58: \n59:         return moved_files\n60: \n61:     def get_summary(self) -> dict[str, int]:\n62:         \"\"\"Get a summary of organized files by category.\"\"\"\n63:         summary: dict[str, int] = {}\n64:         for _, destination in self.actions:\n65:             category = destination.parent.name\n66:             summary[category] = summary.get(category, 0) + 1\n67:         return summary\n68: \n69: \n70: def organize_directory(\n71:     directory: Path, dry_run: bool = False\n72: ) -> list[tuple[Path, Path]]:\n73:     \"\"\"Organize files in a directory.\n74: \n75:     Args:\n76:         directory: Path to the directory to organize.\n77:         dry_run: If True, only preview actions without moving files.\n78: \n79:     Returns:\n80:         List of (source, destination) tuples for moved files.\n81:     \"\"\"\n82:     organizer = FileOrganizer(directory)\n83:     return organizer.organize(dry_run=dry_run)\n\n(End of file - total 83 lines)\n</content>","title":"organizer.py","metadata":{"preview":"\"\"\"Core organizer logic for the file organizer.\"\"\"\n\nfrom pathlib import Path\n\nfrom file_types import get_category\nfrom utils import create_folder, get_files_in_directory, is_directory\n\n\nclass FileOrganizer:\n    \"\"\"Organizes files in a directory into categorized folders.\"\"\"\n\n    def __init__(self, directory: Path):\n        \"\"\"Initialize with a target directory.\"\"\"\n        self.directory = directory\n        self.actions: list[tuple[Path, Path]] = []\n\n    def scan_files(self) -> list[Path]:\n        \"\"\"Scan and return all files in the directory.\"\"\"\n        return get_files_in_directory(self.directory)\n","truncated":false,"loaded":[]},"time":{"start":1772917013199,"end":1772917013200}}}}
