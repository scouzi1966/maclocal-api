{"type":"tool_use","timestamp":1772916345477,"sessionID":"ses_335f55b7affeZUP0UZCwJ3YPvb","part":{"id":"prt_cca0c8a61001sOf0tGOKS35u0h","sessionID":"ses_335f55b7affeZUP0UZCwJ3YPvb","messageID":"msg_cca0c204b001IFceamdqAJnHhP","type":"tool","callID":"call_UhoL7D987Do5Aa9DFqV6PSCh","tool":"write","state":{"status":"completed","input":{"content":"\"\"\"Main entry point for the file organizer CLI.\"\"\"\n\nimport argparse\nimport sys\n\nfrom .organizer import organize_files\nfrom .utils import error, get_summary, print_actions, print_summary, validate_directory\n\n\ndef main() -> int:\n    \"\"\"Main entry point.\"\"\"\n    parser = argparse.ArgumentParser(\n        prog=\"file-organizer\",\n        description=\"Organize files in a directory into categorized folders.\"\n    )\n    \n    subparsers = parser.add_subparsers(dest=\"command\", help=\"Available commands\")\n    \n    # Organize command\n    organize_parser = subparsers.add_parser(\n        \"organize\",\n        help=\"Organize files in a directory\"\n    )\n    organize_parser.add_argument(\n        \"directory\",\n        help=\"Target directory to organize\"\n    )\n    organize_parser.add_argument(\n        \"--dry-run\",\n        action=\"store_true\",\n        help=\"Preview changes without moving files\"\n    )\n    \n    args = parser.parse_args()\n    \n    if not args.command:\n        parser.print_help()\n        return 1\n    \n    if args.command == \"organize\":\n        try:\n            directory = validate_directory(args.directory)\n        except (FileNotFoundError, NotADirectoryError) as e:\n            error(str(e))\n            return 1\n        \n        actions = organize_files(directory, dry_run=args.dry_run)\n        \n        if args.dry_run:\n            if actions:\n                print(\"Preview of organization:\")\n                print_actions(actions)\n                summary = get_summary(actions)\n                print_summary(summary)\n            else:\n                print(\"No files to organize.\")\n        else:\n            if actions:\n                summary = get_summary(actions)\n                print_summary(summary)\n            else:\n                print(\"No files to organize.\")\n        \n        return 0\n    \n    return 1\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())","filePath":"/private/tmp/opencode-serve-test/file_organizer/main.py"},"output":"Wrote file successfully.","title":"file_organizer/main.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-test/file_organizer/main.py","exists":false,"truncated":false},"time":{"start":1772916345442,"end":1772916345476}}}}
