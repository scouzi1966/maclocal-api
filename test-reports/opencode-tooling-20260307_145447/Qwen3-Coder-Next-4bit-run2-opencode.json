{"type":"tool_use","timestamp":1772916318229,"sessionID":"ses_335f55b7affeZUP0UZCwJ3YPvb","part":{"id":"prt_cca0c1fed001ZWsbGjqSs6bebl","sessionID":"ses_335f55b7affeZUP0UZCwJ3YPvb","messageID":"msg_cca0bb1c6001dqVjWHPoVG02K7","type":"tool","callID":"call_zsOjQdTQN7GTeGd25kPfFtiO","tool":"write","state":{"status":"completed","input":{"content":"\"\"\"Utility functions for the file organizer.\"\"\"\n\nimport sys\nfrom pathlib import Path\n\n\ndef validate_directory(directory: str) -> Path:\n    \"\"\"Validate that a directory exists and is accessible.\"\"\"\n    path = Path(directory)\n    if not path.exists():\n        raise FileNotFoundError(f\"Directory not found: {directory}\")\n    if not path.is_dir():\n        raise NotADirectoryError(f\"Path is not a directory: {directory}\")\n    return path.resolve()\n\n\ndef format_action(source: Path, category: str, dest: Path) -> str:\n    \"\"\"Format an action for display.\"\"\"\n    return f\"{source.name} -> {category}/\"\n\n\ndef print_actions(actions: list[tuple]) -> None:\n    \"\"\"Print organization actions in a readable format.\"\"\"\n    for source, category, dest in actions:\n        print(format_action(source, category, dest))\n\n\ndef get_summary(actions: list[tuple]) -> dict:\n    \"\"\"Get a summary of organization actions by category.\"\"\"\n    summary: dict[str, int] = {}\n    for _, category, _ in actions:\n        summary[category] = summary.get(category, 0) + 1\n    return summary\n\n\ndef print_summary(summary: dict) -> None:\n    \"\"\"Print a summary of organization results.\"\"\"\n    print(\"\\nOrganization Summary:\")\n    for category, count in sorted(summary.items()):\n        print(f\"  {category}: {count} file(s)\")\n    print(f\"\\nTotal: {sum(summary.values())} file(s) processed\")\n\n\ndef confirm_prompt(prompt: str) -> bool:\n    \"\"\"Ask for user confirmation.\"\"\"\n    try:\n        response = input(f\"{prompt} [y/N]: \").strip().lower()\n        return response in (\"y\", \"yes\")\n    except (EOFError, KeyboardInterrupt):\n        print(\"\\nCancelled.\")\n        return False\n\n\ndef error(msg: str) -> None:\n    \"\"\"Print an error message to stderr.\"\"\"\n    print(f\"Error: {msg}\", file=sys.stderr)\n\n\ndef success(msg: str) -> None:\n    \"\"\"Print a success message.\"\"\"\n    print(f\"Success: {msg}\")","filePath":"/private/tmp/opencode-serve-test/file_organizer/utils.py"},"output":"Wrote file successfully.","title":"file_organizer/utils.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-test/file_organizer/utils.py","exists":false,"truncated":false},"time":{"start":1772916318190,"end":1772916318227}}}}
