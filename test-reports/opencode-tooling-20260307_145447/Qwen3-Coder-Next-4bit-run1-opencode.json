ory(Path(\"unknown.xyz\")) == \"Other\"\n\n\ndef test_get_all_categories():\n    \"\"\"Test getting all categories.\"\"\"\n    categories = get_all_categories()\n    assert \"Images\" in categories\n    assert \"Documents\" in categories\n    assert \"Videos\" in categories\n    assert \"Archives\" in categories\n    assert \"Audio\" in categories\n    assert \"Code\" in categories\n    assert \"Other\" in categories\n","filePath":"/private/tmp/opencode-serve-test/tests/test_file_types.py"},"output":"Wrote file successfully.","title":"tests/test_file_types.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-test/tests/test_file_types.py","exists":false,"truncated":false},"time":{"start":1772915918087,"end":1772915918116}}}}
