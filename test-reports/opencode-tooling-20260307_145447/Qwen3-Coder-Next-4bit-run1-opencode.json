{"type":"tool_use","timestamp":1772915785003,"sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","part":{"id":"prt_cca03fd0c001PVGL92v8S3wZxR","sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","messageID":"msg_cca03ba180013J9cApFldN1zjC","type":"tool","callID":"call_4rB3NSWMjQavDoj0DR03zyFS","tool":"write","state":{"status":"completed","input":{"content":"\"\"\"Command-line interface for the file organizer.\"\"\"\n\nimport argparse\nimport sys\nfrom pathlib import Path\n\nfrom organizer import organize_directory\n\n\ndef parse_args() -> argparse.Namespace:\n    \"\"\"Parse command-line arguments.\"\"\"\n    parser = argparse.ArgumentParser(\n        description=\"Simple Local File Organizer - Organize files into categorized folders\"\n    )\n    \n    subparsers = parser.add_subparsers(dest=\"command\", help=\"Available commands\")\n    \n    organize_parser = subparsers.add_parser(\n        \"organize\",\n        help=\"Organize files in a directory\"\n    )\n    organize_parser.add_argument(\n        \"directory\",\n        type=str,\n        help=\"Directory to organize\"\n    )\n    organize_parser.add_argument(\n        \"--dry-run\",\n        action=\"store_true\",\n        help=\"Preview organization without moving files\"\n    )\n    \n    return parser.parse_args()\n\n\ndef main() -> int:\n    \"\"\"Main entry point.\"\"\"\n    args = parse_args()\n    \n    if not args.command:\n        print(\"Usage: file-organizer <command>\")\n        print(\"Commands:\")\n        print(\"  organize <directory>  Organize files in a directory\")\n        print(\"\")\n        print(\"Use 'file-organizer organize --help' for more info\")\n        return 1\n    \n    if args.command == \"organize\":\n        directory = Path(args.directory)\n        \n        if not directory.exists():\n            print(f\"Error: Directory '{directory}' does not exist\")\n            return 1\n        \n        if not directory.is_dir():\n            print(f\"Error: '{directory}' is not a directory\")\n            return 1\n        \n        dry_run = args.dry_run\n        \n        if dry_run:\n            print(\"Previewing organization (dry run)...\")\n            print(\"\")\n        \n        moved_files = organize_directory(directory, dry_run=dry_run)\n        \n        if dry_run:\n            if moved_files:\n                for src, dest in moved_files:\n                    print(f\"{src.name} -> {dest.parent.name}/\")\n            else:\n                print(\"No files to organize.\")\n        else:\n            summary = {}\n            for src, dest in moved_files:\n                category = dest.parent.name\n                summary[category] = summary.get(category, 0) + 1\n            \n            print(f\"Organized {len(moved_files)} file(s):\")\n            for category, count in sorted(summary.items()):\n                print(f\"  {category}: {count}\")\n        \n        return 0\n    \n    return 1\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","filePath":"/private/tmp/opencode-serve-test/main.py"},"output":"Wrote file successfully.","title":"main.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-test/main.py","exists":false,"truncated":false},"time":{"start":1772915784973,"end":1772915785001}}}}
