{"type":"tool_use","timestamp":1772915962558,"sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","part":{"id":"prt_cca06b2a0001H6oo3TowIwFIYJ","sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","messageID":"msg_cca0678dc001nTZs25iDxDXVr9","type":"tool","callID":"call_rlIykThDTgzvsywY9DhjCt2U","tool":"write","state":{"status":"completed","input":{"content":"\"\"\"Tests for utils module.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nfrom utils import create_folder, get_files_in_directory, is_file, is_directory\n\n\ndef test_create_folder():\n    \"\"\"Test folder creation.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        folder = Path(tmpdir) / \"new_folder\"\n        create_folder(folder)\n        assert folder.exists()\n        assert folder.is_dir()\n\n\ndef test_get_files_in_directory():\n    \"\"\"Test getting files from a directory.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"file1.txt\").touch()\n        (tmpdir_path / \"file2.jpg\").touch()\n        (tmpdir_path / \"subfolder\").mkdir()\n        \n        files = get_files_in_directory(tmpdir_path)\n        assert len(files) == 2\n        assert all(is_file(f) for f in files)\n\n\ndef test_is_file():\n    \"\"\"Test file detection.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        file_path = tmpdir_path / \"test.txt\"\n        file_path.touch()\n        \n        assert is_file(file_path)\n        assert not is_file(tmpdir_path)\n\n\ndef test_is_directory():\n    \"\"\"Test directory detection.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        \n        assert is_directory(tmpdir_path)\n        assert not is_directory(tmpdir_path / \"nonexistent\")\n","filePath":"/private/tmp/opencode-serve-test/tests/test_utils.py"},"output":"Wrote file successfully.","title":"tests/test_utils.py","metadata":{"diagnostics":{},"filepath":