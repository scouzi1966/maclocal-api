{"type":"tool_use","timestamp":1772915986108,"sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","part":{"id":"prt_cca070e9d0016MCm0f1kn9b5K7","sessionID":"ses_335fe82edffegf3xUTqYmkHwvH","messageID":"msg_cca06b2e3001nGV6pNLlHBUv6P","type":"tool","callID":"call_uK9cpq9wfxebv8kNIPh4ZD13","tool":"write","state":{"status":"completed","input":{"content":"\"\"\"Tests for organizer module.\"\"\"\n\nimport tempfile\nfrom pathlib import Path\n\nfrom organizer import FileOrganizer, organize_directory\n\n\ndef test_organizer_scan_files():\n    \"\"\"Test scanning files in a directory.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"file1.txt\").touch()\n        (tmpdir_path / \"file2.jpg\").touch()\n        \n        organizer = FileOrganizer(tmpdir_path)\n        files = organizer.scan_files()\n        assert len(files) == 2\n\n\ndef test_organizer_get_category():\n    \"\"\"Test getting file category.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"photo.jpg\").touch()\n        \n        organizer = FileOrganizer(tmpdir_path)\n        category = organizer.get_file_category(tmpdir_path / \"photo.jpg\")\n        assert category == \"Images\"\n\n\ndef test_organizer_dry_run():\n    \"\"\"Test dry-run mode.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"document.pdf\").touch()\n        \n        organizer = FileOrganizer(tmpdir_path)\n        moved_files = organizer.organize(dry_run=True)\n        \n        assert len(moved_files) == 1\n        src, dest = moved_files[0]\n        assert src.name == \"document.pdf\"\n        assert dest.parent.name == \"Documents\"\n        assert not (tmpdir_path / \"Documents\").exists()\n\n\ndef test_organizer_move_files():\n    \"\"\"Test actual file organization.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"photo.png\").touch()\n        (tmpdir_path / \"video.mp4\").touch()\n        (tmpdir_path / \"archive.zip\").touch()\n        \n        organizer = FileOrganizer(tmpdir_path)\n        moved_files = organizer.organize(dry_run=False)\n        \n        assert len(moved_files) == 3\n        assert (tmpdir_path / \"Images\").exists()\n        assert (tmpdir_path / \"Videos\").exists()\n        assert (tmpdir_path / \"Archives\").exists()\n        assert (tmpdir_path / \"Images\" / \"photo.png\").exists()\n        assert (tmpdir_path / \"Videos\" / \"video.mp4\").exists()\n        assert (tmpdir_path / \"Archives\" / \"archive.zip\").exists()\n        assert not (tmpdir_path / \"photo.png\").exists()\n        assert not (tmpdir_path / \"video.mp4\").exists()\n        assert not (tmpdir_path / \"archive.zip\").exists()\n\n\ndef test_organizer_summary():\n    \"\"\"Test getting organization summary.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"file1.txt\").touch()\n        (tmpdir_path / \"file2.jpg\").touch()\n        (tmpdir_path / \"file3.pdf\").touch()\n        \n        organizer = FileOrganizer(tmpdir_path)\n        organizer.organize(dry_run=False)\n        \n        summary = organizer.get_summary()\n        assert summary.get(\"Images\") == 1\n        assert summary.get(\"Documents\") == 2\n\n\ndef test_organize_directory_function():\n    \"\"\"Test the organize_directory helper function.\"\"\"\n    with tempfile.TemporaryDirectory() as tmpdir:\n        tmpdir_path = Path(tmpdir)\n        (tmpdir_path / \"test.py\").touch()\n        \n        moved_files = organize_directory(tmpdir_path, dry_run=False)\n        \n        assert len(moved_files) == 1\n        assert (tmpdir_path / \"Code\").exists()\n        assert (tmpdir_path / \"Code\" / \"test.py\").exists()\n","filePath":"/private/tmp/opencode-serve-test/tests/test_organizer.py"},"output":"Wrote file successfully.","title":"tests/test_organizer.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-test/tests/test_organizer.py","exists":false,"truncated":false},"time":{"start":1772915986078,"end":1772915986107}}}}
