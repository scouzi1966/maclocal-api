{"type":"tool_use","timestamp":1772939714419,"sessionID":"ses_33490879cffezdD5Hp4ky5u8mh","part":{"id":"prt_ccb70e1bc001rU6rxHfl1cZgQm","sessionID":"ses_33490879cffezdD5Hp4ky5u8mh","messageID":"msg_ccb70c4ee001Dt5CmOQbZZC8eQ","type":"tool","callID":"call_90158FBDC51F4D358A329C15","tool":"write","state":{"status":"completed","input":{"content":"import os\nimport shutil\nfrom file_types import FILE_TYPES, CATEGORIES\nfrom utils import get_file_extension, get_file_category, get_destination_folder, create_folder_if_not_exists, get_unique_filename\n\n\nclass FileOrganizer:\n    def __init__(self, base_path, dry_run=False):\n        self.base_path = os.path.abspath(base_path)\n        self.dry_run = dry_run\n        self.stats = {\n            'total_files': 0,\n            'organized_files': 0,\n            'skipped_files': 0,\n            'errors': [],\n            'categories': {category: 0 for category in CATEGORIES},\n            'others': 0\n        }\n\n    def get_files_to_organize(self):\n        files = []\n        try:\n            for item in os.listdir(self.base_path):\n                item_path = os.path.join(self.base_path, item)\n                if os.path.isfile(item_path):\n                    files.append((item_path, item))\n        except Exception as e:\n            self.stats['errors'].append(f\"Error reading directory: {e}\")\n        return files\n\n    def organize_file(self, file_path, filename):\n        extension = get_file_extension(filename)\n        category = get_file_category(extension, FILE_TYPES)\n        dest_folder = get_destination_folder(self.base_path, category)\n        dest_path = os.path.join(dest_folder, filename)\n\n        file_size = os.path.getsize(file_path)\n\n        if category == 'others':\n            self.stats['skipped_files'] += 1\n            self.stats['others'] += 1\n            return False\n\n        try:\n            if self.dry_run:\n                if os.path.exists(dest_path):\n                    dest_path = os.path.join(dest_folder, get_unique_filename(dest_folder, filename))\n                print(f\"[DRY-RUN] Would move: {filename} ({file_size} bytes) -> {dest_folder}/\")\n                self.stats['organized_files'] += 1\n                self.stats['categories'][category] += 1\n            else:\n                create_folder_if_not_exists(dest_folder)\n                if os.path.exists(dest_path):\n                    dest_path = os.path.join(dest_folder, get_unique_filename(dest_folder, filename))\n                    print(f\"Renamed to: {os.path.basename(dest_path)}\")\n                shutil.move(file_path, dest_path)\n                print(f\"Moved: {filename} -> {dest_folder}/\")\n                self.stats['organized_files'] += 1\n                self.stats['categories'][category] += 1\n\n            return True\n\n        except Exception as e:\n            self.stats['errors'].append(f\"Error moving {filename}: {e}\")\n            self.stats['skipped_files'] += 1\n            return False\n\n    def organize(self):\n        print(f\"Organizing files in: {self.base_path}\")\n        if self.dry_run:\n            print(\"Running in DRY-RUN mode - no files will be moved\\n\")\n        else:\n            print(\"\")\n\n        files = self.get_files_to_organize()\n        self.stats['total_files'] = len(files)\n\n        if not files:\n            print(\"No files found to organize.\")\n            return\n\n        for file_path, filename in files:\n            self.organize_file(file_path, filename)\n\n        print(\"\")\n        self.print_summary()\n\n    def print_summary(self):\n        print(\"=\" * 50)\n        print(\"Organization Summary\")\n        print(\"=\" * 50)\n        print(f\"Total files found: {self.stats['total_files']}\")\n        print(f\"Files organized: {self.stats['organized_files']}\")\n        print(f\"Files skipped: {self.stats['skipped_files']}\")\n\n        if self.stats['categories']:\n            print(\"\\nFiles by category:\")\n            for category, count in sorted(self.stats['categories'].items()):\n                if count > 0:\n                    print(f\"  {category.capitalize()}: {count}\")\n\n        if self.stats['others'] > 0:\n            print(f\"  Others (unrecognized): {self.stats['others']}\")\n\n        if self.stats['errors']:\n            print(f\"\\nErrors ({len(self.stats['errors'])}):\")\n            for error in self.stats['errors']:\n                print(f\"  - {error}\")\n        print(\"=\" * 50)","filePath":"/private/tmp/opencode-serve-20260307_220918/organizer.py"},"output":"Wrote file successfully.","title":"organizer.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_220918/organizer.py","exists":false,"truncated":false},"time":{"start":1772939714385,"end":1772939714417}}}}
