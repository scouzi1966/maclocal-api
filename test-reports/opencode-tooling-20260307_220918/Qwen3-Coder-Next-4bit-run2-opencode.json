{"type":"tool_use","timestamp":1772939691209,"sessionID":"ses_33490879cffezdD5Hp4ky5u8mh","part":{"id":"prt_ccb70afbe001gVzrgvXW7r3hVh","sessionID":"ses_33490879cffezdD5Hp4ky5u8mh","messageID":"msg_ccb7091c10011WGE3CO2wYt0BG","type":"tool","callID":"call_C28960486CA04DADBC3AFEE4","tool":"write","state":{"status":"completed","input":{"filePath":"/private/tmp/opencode-serve-20260307_220918/utils.py","content":"import os\nfrom datetime import datetime\n\n\ndef get_file_extension(filename):\n    return os.path.splitext(filename)[1].lower()\n\n\ndef get_file_category(extension, file_types):\n    for category, extensions in file_types.FILE_TYPES.items():\n        if extension in extensions:\n            return category\n    return 'others'\n\n\ndef get_destination_folder(base_path, category):\n    return os.path.join(base_path, category.capitalize())\n\n\ndef create_folder_if_not_exists(folder_path):\n    if not os.path.exists(folder_path):\n        os.makedirs(folder_path)\n        return True\n    return False\n\n\ndef get_unique_filename(destination_path, filename):\n    base, extension = os.path.splitext(filename)\n    counter = 1\n    new_filename = filename\n    while os.path.exists(os.path.join(destination_path, new_filename)):\n        new_filename = f\"{base}_{counter}{extension}\"\n        counter += 1\n    return new_filename\n\n\ndef format_size(size_bytes):\n    for unit in ['B', 'KB', 'MB', 'GB']:\n        if size_bytes >= 1024:\n            size_bytes /= 1024\n        else:\n            return f\"{size_bytes:.2f} {unit}\"\n    return f\"{size_bytes:.2f} TB\"\n\n\ndef format_timestamp(timestamp):\n    return datetime.fromtimestamp(timestamp).strftime('%Y-%m-%d %H:%M:%S')"},"output":"Wrote file successfully.","title":"utils.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_220918/utils.py","exists":false,"truncated":false},"time":{"start":1772939691176,"end":1772939691207}}}}
