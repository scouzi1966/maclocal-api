{"type":"tool_use","timestamp":1772940082449,"sessionID":"ses_3348e0163ffeFtFJ2HegZwDwbo","part":{"id":"prt_ccb76a672001k4CTFPP33EoEwz","sessionID":"ses_3348e0163ffeFtFJ2HegZwDwbo","messageID":"msg_ccb76781d001fIriVDpZNdZKa2","type":"tool","callID":"call_1610AE3015FF47D082BE75CC","tool":"write","state":{"status":"completed","input":{"content":"import os\nfrom datetime import datetime\n\n\ndef get_file_size(size_bytes):\n    \"\"\"Convert bytes to human-readable format.\"\"\"\n    if size_bytes == 0:\n        return \"0B\"\n    units = ['B', 'KB', 'MB', 'GB', 'TB']\n    i = 0\n    while size_bytes >= 1024 and i len(units) - 1:\n        size_bytes /= 1024\n        i += 1\n    return f\"{size_bytes:.2f}{units[i]}\"\n\n\ndef get_file_modified_date(filepath):\n    \"\"\"Get file modification date.\"\"\"\n    return datetime.fromtimestamp(os.path.getmtime(filepath))\n\n\ndef format_date(dt):\n    \"\"\"Format datetime for display.\"\"\"\n    return dt.strftime('%Y-%m-%d %H:%M:%S')\n\n\ndef ensure_directory(directory):\n    \"\"\"Create directory if it doesn't exist.\"\"\"\n    if not os.path.exists(directory):\n        os.makedirs(directory)\n        return True\n    return False\n\n\ndef get_file_extension(filepath):\n    \"\"\"Get file extension in lowercase.\"\"\"\n    return os.path.splitext(filepath)[1].lower()\n\n\ndef is_valid_file(filepath):\n    \"\"\"Check if path is a valid file.\"\"\"\n    return os.path.isfile(filepath)\n\n\ndef get_file_category(extension):\n    \"\"\"Get category for a file extension.\"\"\"\n    from file_types import EXTENSION_TO_CATEGORY\n    return EXTENSION_TO_CATEGORY.get(extension, 'other')","filePath":"/private/tmp/opencode-serve-20260307_220918/utils.py"},"output":"Wrote file successfully.","title":"utils.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_220918/utils.py","exists":true,"truncated":false},"time":{"start":1772940082417,"end":1772940082448}}}}
