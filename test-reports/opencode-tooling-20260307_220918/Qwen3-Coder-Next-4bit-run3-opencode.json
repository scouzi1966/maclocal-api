{"type":"tool_use","timestamp":1772939863481,"sessionID":"ses_3348e0163ffeFtFJ2HegZwDwbo","part":{"id":"prt_ccb732d6e001AW0x760a4EefUb","sessionID":"ses_3348e0163ffeFtFJ2HegZwDwbo","messageID":"msg_ccb73176b001Z1c0o7XxbmDRWO","type":"tool","callID":"call_DA484CF9F9B9467F824D1226","tool":"write","state":{"status":"completed","input":{"content":"import os\nimport shutil\nfrom file_types import EXTENSION_TO_CATEGORY\nfrom utils import get_file_category, get_file_extension, ensure_directory\n\n\nclass FileOrganizer:\n    def __init__(self, source_dir, dest_dir, dry_run=False):\n        self.source_dir = os.path.abspath(source_dir)\n        self.dest_dir = os.path.abspath(dest_dir)\n        self.dry_run = dry_run\n        self.moves = []\n        self.errors = []\n        self.skipped = []\n\n    def organize(self):\n        \\\"\\\"\\\"Organize files from source to destination.\\\"\\\"\\\"\n        if not os.path.exists(self.source_dir):\n            self.errors.append(f\\\"Source directory does not exist: {self.source_dir}\\\")\n            return False\n\n        self.moves = []\n        self.errors = []\n        self.skipped = []\n\n        for item in os.listdir(self.source_dir):\n            item_path = os.path.join(self.source_dir, item)\n            \n            if os.path.isfile(item_path):\n                self._process_file(item_path, item)\n            elif os.path.isdir(item_path):\n                self.skipped.append(f\\\"Skipping directory: {item}\\\")\n\n        return True\n\n    def _process_file(self, filepath, filename):\n        \\\"\\\"\\\"Process a single file.\\\"\\\"\\\"\n        try:\n            extension = get_file_extension(filename)\n            category = get_file_category(extension)\n            \n            if category == 'other':\n                self.skipped.append(f\\\"Unknown file type: {filename}\\\")\n                return\n\n            dest_folder = os.path.join(self.dest_dir, category)\n            dest_path = os.path.join(dest_folder, filename)\n\n            self.moves.append({\n                'source': filepath,\n                'destination': dest_path,\n                'category': category\n            })\n\n            if not self.dry_run:\n                ensure_directory(dest_folder)\n                shutil.move(filepath, dest_path)\n\n        except Exception as e:\n            self.errors.append(f\\\"Error processing {filename}: {str(e)}\\\")\n\n    def get_summary(self):\n        \\\"\\\"\\\"Get summary of organized files.\\\"\\\"\\\"\n        category_counts = {}\n        for move in self.moves:\n            category = move['category']\n            category_counts[category] = category_counts.get(category, 0) + 1\n\n        return {\n            'total_moved': len(self.moves),\n            'total_skipped': len(self.skipped),\n            'total_errors': len(self.errors),\n            'by_category': category_counts\n        }\n\n    def print_summary(self):\n        \\\"\\\"\\\"Print summary of the organization.\\\"\\\"\\\"\n        summary = self.get_summary()\n        \n        print(\\\"\\\\n\" + \"=\" * 50)\n        print(\\\"ORGANIZATION SUMMARY\\\")\n        print(\"=\" * 50)\n        \n        if self.dry_run:\n            print(\\\"[DRY RUN MODE - No files were moved]\\\")\n            print(\\\"\\\\nFiles that would be moved:\\\")\n        else:\n            print(\\\"\\\\nFiles moved:\\\")\n        \n        for move in self.moves:\n            print(f\\\"  {move['source']} -> {move['destination']}\\\")\n        \n        if self.skipped:\n            print(\\\"\\\\nSkipped:\\\")\n            for item in self.skipped:\n                print(f\\\"  {item}\\\")\n        \n        if self.errors:\n            print(\\\"\\\\nErrors:\\\")\n            for error in self.errors:\n                print(f\\\"  {error}\\\")\n        \n        print(\\\"\\\\n\\\" + \"-\" * 50)\n        print(f\\\"Total moved: {summary['total_moved']}\\\")\n        print(f\\\"Total skipped: {summary['total_skipped']}\\\")\n        print(f\\\"Total errors: {summary['total_errors']}\\\")\n        print(\\\"\\\\nBy category:\\\")\n        for category, count in summary['by_category'].items():\n            print(f\\\"  {category}: {count}\\\")\n        print(\"=\" * 50)\n\"}}","filePath":"/private/tmp/opencode-serve-20260307_220918/organizer.py"},"output":"Wrote file successfully.","title":"organizer.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_220918/organizer.py","exists":false,"truncated":false},"time":{"start":1772939863447,"end":1772939863480}}}}
