{"type":"tool_use","timestamp":1772939553818,"sessionID":"ses_334935fe4ffe0E4TC0I1oNwS3H","part":{"id":"prt_ccb6e7ad0001QpesaL7TqHtAgK","sessionID":"ses_334935fe4ffe0E4TC0I1oNwS3H","messageID":"msg_ccb6e5990001Gn1yedfZioJFtt","type":"tool","callID":"call_9F9939AC189A40DF8DBFE8B4","tool":"write","state":{"status":"completed","input":{"filePath":"/private/tmp/opencode-serve-20260307_220918/organizer.py","content":"import os\nimport shutil\nfrom file_types import EXTENSION_TO_CATEGORY\n\n\ndef get_extension(filename):\n    return os.path.splitext(filename)[1].lower()\n\n\ndef get_category(filename):\n    ext = get_extension(filename)\n    return EXTENSION_TO_CATEGORY.get(ext, \"unknown\")\n\n\ndef should_process_file(filename, include_patterns=None, exclude_patterns=None):\n    if include_patterns:\n        for pattern in include_patterns:\n            if pattern.lower() in filename.lower():\n                break\n        else:\n            return False\n\n    if exclude_patterns:\n        for pattern in exclude_patterns:\n            if pattern.lower() in filename.lower():\n                return False\n\n    return True\n\n\ndef get_destination_path(category, base_path, filename):\n    category_dir = os.path.join(base_path, category)\n    os.makedirs(category_dir, exist_ok=True)\n    return os.path.join(category_dir, filename)\n\n\ndef organize_files(source_dir, base_dir, dry_run=False):\n    if not os.path.exists(source_dir):\n        print(f\"Error: Source directory '{source_dir}' does not exist\")\n        return False\n\n    if not os.path.isdir(source_dir):\n        print(f\"Error: '{source_dir}' is not a directory\")\n        return False\n\n    files_processed = 0\n    files_skipped = 0\n    files_failed = 0\n    moved_files = []\n\n    print(f\"\\nOrganizing files from: {source_dir}\")\n    if dry_run:\n        print(\"Mode: DRY-RUN (no files will be moved)\")\n    print(f\"Target organization: {base_dir}\\n\")\n\n    for filename in os.listdir(source_dir):\n        filepath = os.path.join(source_dir, filename)\n\n        if os.path.isdir(filepath):\n            print(f\"Skipping directory: {filename}\")\n            files_skipped += 1\n            continue\n\n        if filename.startswith(\".\"):\n            print(f\"Skipping hidden file: {filename}\")\n            files_skipped += 1\n            continue\n\n        category = get_category(filename)\n\n        if category == \"unknown\":\n            print(f\"Unknown file type: {filename}\")\n            files_skipped += 1\n            continue\n\n        dest_dir = os.path.join(base_dir, category)\n        dest_path = os.path.join(dest_dir, filename)\n\n        if dry_run:\n            if not os.path.exists(dest_dir):\n                print(f\"[DRY-RUN] Would create directory: {dest_dir}\")\n            print(f\"[DRY-RUN] Would move: {filepath} -> {dest_path}\")\n            moved_files.append((filepath, dest_path))\n            files_processed += 1\n            continue\n\n        try:\n            os.makedirs(dest_dir, exist_ok=True)\n            shutil.move(filepath, dest_path)\n            print(f\"Moved: {filename} -> {category}/\")\n            moved_files.append((filepath, dest_path))\n            files_processed += 1\n        except Exception as e:\n            print(f\"Error moving {filename}: {e}\")\n            files_failed += 1\n\n    print(f\"\\n{'=' * 50}\")\n    print(f\"Organization complete!\")\n    print(f\"Files processed: {files_processed}\")\n    print(f\"Files skipped: {files_skipped}\")\n    print(f\"Files failed: {files_failed}\")\n    print(f\"{'=' * 50}\\n\")\n\n    return files_processed > 0 or files_skipped > 0\n"},"output":"Wrote file successfully.","title":"organizer.py","metadata":{"diagnostics":{},"filepath":"/private/tmp/opencode-serve-20260307_220918/organizer.py","exists":true,"truncated":false},"time":{"start":1772939553786,"end":1772939553817}}}}
