--- a/src/emitter.ts
+++ b/src/emitter.ts
@@ -1,8 +1,5 @@
 /**
- * A tiny event emitter.
- *
- * NOTE: `off` and `once` are not implemented correctly — see issue.md. `on`,
- * `emit`, and `listenerCount` work.
+ * A tiny event emitter supporting on / off / once / emit.
  */
 
 export type Listener = (...args: unknown[]) => void;
@@ -17,24 +14,31 @@ export class Emitter {
     this.listeners.set(event, fns);
   }
 
-  /** Unsubscribe `fn` from `event`. */
+  /** Unsubscribe `fn` from `event` (removes a single matching listener). */
   off(event: string, fn: Listener): void {
