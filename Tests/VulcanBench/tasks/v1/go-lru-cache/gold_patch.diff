+	}
 }
 
-// Get returns the value for key and whether it was present.
+// Get returns the value for key and whether it was present. A hit marks the key
+// as most-recently-used; a miss does not change recency.
 func (c *Cache) Get(key string) (int, bool) {
-	v, ok := c.data[key]
-	return v, ok
+	el, ok := c.items[key]
+	if !ok {
+		return 0, false
+	}
+	c.ll.MoveToFront(el)
+	return el.Value.(*entry).value, true
 }
 
-// Put inserts or updates the value for key.
+// Put inserts or updates the value for key and marks it most-recently-used,
+// evicting the least-recently-used entry if capacity would be exceeded.
 func (c *Cache) Put(key string, value int) {
-	c.data[key] = value
+	if el, ok := c.items[key]; ok {
+		el.Value.(*entry).value = value
+		c.ll.MoveToFront(el)
+		return
+	}
+	el := c.ll.PushFront(&entry{key: key, value: value})
+	c.items[key] = el
+	if c.capacity > 0 && c.ll.Len() > c.capacity {
+		back := c.ll.Back()
+		if back != nil {
+			c.ll.Remove(back)
+			delete(c.items, back.Value.(*entry).key)
+		}
+	}
 }
 
 // Len reports how many entries are currently stored.
