diff --git a/resilient/backoff.py b/resilient/backoff.py
new file mode 100644
index 0000000..94b2974
--- /dev/null
+++ b/resilient/backoff.py
@@ -0,0 +1,33 @@
+"""Shared retry-with-exponential-backoff helper used by every client."""
+from __future__ import annotations
+
+from typing import Callable, TypeVar
+
+T = TypeVar("T")
+
+
+def retry(
+    operation: Callable[[], T],
+    *,
+    max_attempts: int,
+    base_delay: float,
+    max_delay: float,
+    sleep: Callable[[float], None],
+) -> T:
+    """Call ``operation`` up to ``max_attempts`` times, returning its result.
+
+    Before the k-th retry (k = 1, 2, …) it sleeps ``min(base_delay * 2**(k-1),
+    max_delay)``. If every attempt fails, the last exception is re-raised.
+    """
+    if max_attempts < 1:
+        raise ValueError("max_attempts must be >= 1")
+    last_exc: BaseException | None = None
+    for attempt in range(max_attempts):
+        if attempt > 0:
+            sleep(min(base_delay * 2 ** (attempt - 1), max_delay))
+        try:
+            return operation()
+        except Exception as exc:  # noqa: BLE001 — retry on any operation failure
+            last_exc = exc
+    assert last_exc is not None
+    raise last_exc
