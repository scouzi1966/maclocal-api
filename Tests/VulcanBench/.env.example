# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# PostgreSQL (used by docker-compose.yml and backend/app.py when DATABASE_URL is set)
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+psycopg://vulcanbench:change_me_in_production@localhost:5432/vulcanbench

# Shared secret for the API's write endpoints (POST /api/runs, /api/feedback).
# Writes are disabled (503) until this is set on the server; clients send it as
# "Authorization: Bearer <token>".
VULCANBENCH_API_TOKEN=change_me_in_production

# Optional: post run summaries to the API after each vulcanbench run (write-through).
# Requires the server to have DATABASE_URL and VULCANBENCH_API_TOKEN configured.
# VULCANBENCH_API_BASE=http://localhost:8000

# Restrict browser origins for the API in production (comma-separated; default *)
# VULCANBENCH_CORS_ORIGINS=https://bench.example.com

# Explicit opt-in for `--sandbox auto` to fall back to host execution when the
# Docker daemon is unavailable. Leave unset in production.
# VULCANBENCH_ALLOW_HOST_EXEC=1

# Optional: override default sandbox image (default: vulcanbench/sandbox:base)
# VULCANBENCH_SANDBOX_IMAGE=vulcanbench/sandbox:base

# Optional: point the harness at a different runs directory (default: ./runs)
# VULCANBENCH_RUNS_DIR=./runs

# Optional: override the tasks root
# VULCANBENCH_TASKS_ROOT=tasks/v1

# Optional: override model pricing table (JSON file path)
# VULCANBENCH_PRICING=/path/to/prices.json

# LLM provider keys (only the ones you use are required)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for compatible endpoints
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ZAI_API_KEY=...                              # for zai:* models (GLM)
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4   # optional override

# Dashboard (set in dashboard/.env.local — see dashboard/.env.example)
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_REPO=morganlinton/VulcanBench
